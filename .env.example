# =============================================================================
# Air Quality Intelligence Platform — environment configuration TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values:   cp .env.example .env
# NEVER commit your real .env (it is git-ignored). NEVER put real secrets here.
# =============================================================================

# --- AWS / S3 (data lake: raw + processed layers) ---
# Leave AWS_* blank to run fully locally — the pipeline falls back to the
# mounted ./data folder and simply skips S3 uploads.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=
S3_RAW_PREFIX=raw
S3_PROCESSED_PREFIX=processed

# --- PostgreSQL (final dashboard database) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=air_quality
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow

# --- Airflow (orchestration) ---
# Run Airflow containers as your HOST user so they can write to mounted ./data.
# On Linux set this to your uid:  echo "AIRFLOW_UID=$(id -u)" >> .env
# (1000 is the typical uid for the default Ubuntu user on EC2.)
AIRFLOW_UID=50000
# FastAPI calls this base URL to trigger the DAG via the REST API.
AIRFLOW_BASE_URL=http://airflow-webserver:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
DAG_ID=air_quality_pipeline

# --- Service URLs ---
# Streamlit uses this to reach FastAPI.
FASTAPI_URL=http://fastapi:8000

# --- Data sources (all optional; fallback sample data used if absent) ---
# OpenAQ v3 needs a free API key. Open-Meteo needs no key.
OPENAQ_API_KEY=
OPENAQ_BASE_URL=https://api.openaq.org/v3
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# --- Local data lake path (mounted into containers) ---
DATA_DIR=/opt/airflow/data

# --- Behaviour ---
# When true, network/credential failures fall back to bundled sample data.
USE_FALLBACK_ON_ERROR=true

# --- Cities (comma-separated; optional override of the defaults) ---
# CITIES=Berlin,Munich,Paris,London,Delhi,Kolkata
